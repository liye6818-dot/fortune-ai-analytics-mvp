# Runtime
NODE_ENV=development
APP_NAME=fortune-order-assistant
APP_BASE_URL=http://localhost:3000
PORT=3000

# Admin
# Generate a real hash in production; never commit a plaintext admin password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace-with-argon2-or-bcrypt-hash
SESSION_SECRET=replace-with-long-random-session-secret

# SQLite
DATABASE_URL=sqlite:./database/runtime/app.sqlite
SQLITE_BUSY_TIMEOUT_MS=5000
SQLITE_WAL_ENABLED=true

# Uploads / logs / backups
UPLOAD_DIR=./uploads
LOG_DIR=./logs
BACKUP_DIR=./backups

# Auth and devices
SECURITY_CODE_PEPPER=replace-with-long-random-pepper
DEFAULT_CLIENT_MODE=standalone
DEFAULT_DEVICE_LIMIT=1

# WebSocket
WEBSOCKET_ENABLED=false
WEBSOCKET_PATH=/ws

# External integrations
OPENAI_API_KEY=
LOTTERY_API_BASE_URL=
